[project]
requires = ["nodejs-24"]

[dev]
build = ["pnpm", "install"]
run = ["cd", "server", "&&", "PORT=3000", "pnpm", "dev"]

[deploy]
build = ["pnpm", "install", "&&", "cd", "server", "&&", "pnpm", "install", "&&", "pnpm", "run", "build"]
run = ["cd", "server", "&&", "PORT=5000", "pnpm", "start"]
